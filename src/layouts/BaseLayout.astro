---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Todd Hainsworth — Senior Software Engineer' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'Gear', href: '/gear' },
  { label: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="wordmark">todd hainsworth</a>
          <ul>
            {nav.map(({ label, href }) => (
              <li>
                <a href={href} class={currentPath.startsWith(href) ? 'active' : ''}>{label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <span>© {new Date().getFullYear()} Todd Hainsworth</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  header nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  header nav .wordmark {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
  }

  header nav .wordmark:hover {
    color: var(--accent);
    text-decoration: none;
  }

  header nav ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin-left: auto;
  }

  header nav ul a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  header nav ul a:hover,
  header nav ul a.active {
    color: var(--text);
    text-decoration: none;
  }

  main.container {
    flex: 1;
    padding-top: 40px;
    padding-bottom: 4rem;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>

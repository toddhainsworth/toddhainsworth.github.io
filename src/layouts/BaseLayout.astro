---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Todd Hainsworth — Senior Software Engineer' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'Gear', href: '/gear' },
  { label: 'Contact', href: '/contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="wordmark">todd hainsworth</a>
          <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
          </button>
          <ul>
            {nav.map(({ label, href }) => (
              <li>
                <a href={href} class={currentPath.startsWith(href) ? 'active' : ''}>{label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <div class="nav-overlay" aria-hidden="true"></div>

    <footer>
      <div class="container">
        <span>© {new Date().getFullYear()} Todd Hainsworth</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const ul = document.querySelector('header nav ul') as HTMLUListElement;
  const overlay = document.querySelector('.nav-overlay') as HTMLDivElement;

  function closeMenu() {
    ul.classList.remove('open');
    overlay.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    toggle?.classList.remove('open');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = ul.classList.toggle('open');
    overlay.classList.toggle('open', isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.classList.toggle('open', isOpen);
  });

  overlay?.addEventListener('click', closeMenu);

  ul?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>

<style is:global>
  header {
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  header nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  header nav .wordmark {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
  }

  header nav .wordmark:hover {
    color: var(--accent);
    text-decoration: none;
  }

  header nav ul {
    display: flex;
    list-style: none;
    gap: 1.5rem;
    margin-left: auto;
  }

  header nav ul li {
    list-style: none;
  }

  header nav ul a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  header nav ul a:hover,
  header nav ul a.active {
    color: var(--text);
    text-decoration: none;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    margin-left: auto;
    flex-direction: column;
    gap: 5px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: transform 0.2s, opacity 0.2s;
  }

  .menu-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: flex;
    }

    header nav ul {
      display: none;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 1rem 1.5rem;
      gap: 1rem;
    }

    header nav ul.open {
      display: flex;
    }

    header nav ul a {
      font-size: 1rem;
    }
  }

  .nav-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .nav-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  main.container {
    flex: 1;
    padding-top: 40px;
    padding-bottom: 4rem;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>

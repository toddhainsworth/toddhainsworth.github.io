---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  {
    label: 'GitHub',
    href: 'https://github.com/toddhainsworth/',
    display: 'github.com/toddhainsworth',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/todd-hainsworth-21573164/',
    display: 'linkedin.com/in/todd-hainsworth',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:hainsworth.todd@gmail.com',
    display: 'hainsworth.todd@gmail.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: 'Resume',
    href: 'https://drive.google.com/file/d/1i86y1u_aa083Ii81z7yfJ9eLnid1XF47/view?usp=drive_link',
    display: 'View',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
];
---

<BaseLayout title="Contact — Todd Hainsworth" description="Ways to get in touch with Todd Hainsworth.">
  <h1>Contact</h1>
  <p class="intro">The best ways to reach me.</p>

  <ul class="contact-list">
    {links.map(({ label, href, display, icon }) => (
      <li>
        <div class="label">
          <span set:html={icon} />
          {label}
        </div>
        <a href={href} target={href.startsWith('mailto') ? undefined : '_blank'} rel="noopener">{display}</a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .intro {
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  li {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .label {
    display: flex;
    align-items: center;
    gap: calc(0.5rem + 5px);
    font-size: 0.875rem;
    color: var(--text-muted);
    min-width: 100px;
  }

  .label :global(svg) {
    transform: translateY(3px);
    flex-shrink: 0;
  }

  a {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>

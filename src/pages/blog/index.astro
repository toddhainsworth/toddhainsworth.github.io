---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Todd Hainsworth" description="Writing on software, teams, and craft.">
  <h1>Blog</h1>

  {posts.length === 0 ? (
    <p class="empty">Nothing here yet. Check back soon.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            <time datetime={post.data.date.toISOString()}>
              {new Intl.DateTimeFormat('en-AU', { year: 'numeric', month: 'short', day: 'numeric' }).format(post.data.date)}
            </time>
          </a>
          <p class="post-description">{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--text-muted);
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--text);
    text-decoration: none;
  }

  .post-list a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    font-weight: 500;
  }

  .post-list time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-description {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }
</style>

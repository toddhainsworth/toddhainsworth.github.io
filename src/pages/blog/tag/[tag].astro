---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const knownTags = ['neovim', 'ai', 'aws-cdk', 'gadget', 'typescript', 'go', 'rust'];
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const postTags = posts.flatMap((p) => p.data.tags);
  const allTags = [...new Set([...knownTags, ...postTags])];
  return allTags.map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={`#${tag} — Todd Hainsworth`} description={`Blog posts tagged with ${tag}.`}>
  <div class="tag-header">
    <a href="/blog" class="back-link">← Blog</a>
    <h1><span class="hash">#</span>{tag}</h1>
    <p class="count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  </div>

  {sorted.length === 0 ? (
    <p class="empty">No posts yet.</p>
  ) : (
    <ul class="post-list">
      {sorted.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            <time datetime={post.data.date.toISOString()}>
              {new Intl.DateTimeFormat('en-AU', { year: 'numeric', month: 'short', day: 'numeric' }).format(post.data.date)}
            </time>
          </a>
          <p class="post-description">{post.data.description}</p>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  .tag-header {
    margin-bottom: 2.5rem;
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .hash {
    color: var(--accent);
  }

  .count {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .empty {
    color: var(--text-muted);
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    color: var(--text);
    text-decoration: none;
  }

  .post-list a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    font-weight: 500;
  }

  .post-list time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-description {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }
</style>
